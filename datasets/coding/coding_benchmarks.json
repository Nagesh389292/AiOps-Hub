    "unit_tests": [
      "assert fibonacci(0) == 0",
      "assert fibonacci(7) == 13"
    ],
    "hidden_tests": [
      "assert fibonacci(1) == 1",
      "assert fibonacci(8) == 21"
    ]
  },
  {
    "problem_id": 3,
    "title": "Reverse String",
    "prompt": "Write a Python function reverse_string(s) that returns the reversed string.",
    "unit_tests": [
      "assert reverse_string('abc') == 'cba'",
      "assert reverse_string('') == ''"
    ],
    "hidden_tests": [
      "assert reverse_string('level') == 'level'",
      "assert reverse_string('AIOps') == 'spOIA'"
    ]
  },
  {
    "problem_id": 4,
    "title": "Two Sum",
    "prompt": "Write a Python function two_sum(nums, target) that returns indices of two numbers adding to target.",
    "unit_tests": [
      "assert set(two_sum([2,7,11,15],9)) == {0,1}",
      "assert set(two_sum([3,2,4],6)) == {1,2}"
    ],
    "hidden_tests": [
      "assert set(two_sum([3,3],6)) == {0,1}",
      "assert set(two_sum([1,5,9,11],10)) == {0,2}"
    ]
  },
  {
    "problem_id": 5,
    "title": "Binary Search",
    "prompt": "Write a Python function binary_search(arr, target) that returns index of target or -1.",
    "unit_tests": [
      "assert binary_search([1,2,3,4,5], 4) == 3",
      "assert binary_search([1,2,3,4,5], 6) == -1"
    ],
    "hidden_tests": [
      "assert binary_search([], 1) == -1",
      "assert binary_search([10], 10) == 0"
    ]
  },
  {
    "problem_id": 6,
    "title": "Merge Sorted Arrays",
    "prompt": "Write a Python function merge_sorted_arrays(a, b) that merges two sorted lists.",
    "unit_tests": [
      "assert merge_sorted_arrays([1,3,5], [2,4,6]) == [1,2,3,4,5,6]",
      "assert merge_sorted_arrays([], [1,2]) == [1,2]"
    ],
    "hidden_tests": [
      "assert merge_sorted_arrays([1,1,2], [1,3]) == [1,1,1,2,3]",
      "assert merge_sorted_arrays([], []) == []"
