    "title": "Factorial",
    "prompt": "Write a Python function factorial(n) that returns n factorial.",
    "unit_tests": [
      "assert factorial(5) == 120",
      "assert factorial(0) == 1"
    ],
    "hidden_tests": [
      "assert factorial(1) == 1",
      "assert factorial(6) == 720"
    ]
  },
